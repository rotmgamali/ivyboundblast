<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ivybound.scraper</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/mac/Ivybound/launch_scraper.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>/Users/mac/Ivybound</string>
    <key>StandardOutPath</key>
    <string>/Users/mac/Ivybound/scraper_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mac/Ivybound/scraper_stderr.log</string>
</dict>
</plist>
